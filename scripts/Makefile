	  -e 's!@''pkgincludedir''@!$(pkgincludedir)!g' \
	  -e 's!@''CC''@!gcc!'\
	  -e 's!@''CXX''@!ccache gcc!'\
	  -e 's!@''GXX''@!yes!'\
	  -e 's!@''CC_VERSION''@!2.95.3!'\
	  -e 's!@''CXX_VERSION''@!2.95.3!'\
	  -e 's!@''PERL''@!/usr/bin/perl!' \
	  -e 's!@''ASFLAGS''@!!'\
	  -e 's!@''CFLAGS''@!-Wimplicit -Wreturn-type -Wswitch -Wtrigraphs -Wcomment -W -Wchar-subscripts -Wformat -Wparentheses -Wsign-compare -Wwrite-strings -Wunused -mcpu=pentiumpro -O3 -fno-omit-frame-pointer!'\
	  -e 's!@''CXXFLAGS''@!-Wimplicit -Wreturn-type -Wswitch -Wtrigraphs -Wcomment -W -Wchar-subscripts -Wformat -Wparentheses -Wsign-compare -Wwrite-strings -Woverloaded-virtual -Wsign-promo -Wreorder -Wctor-dtor-privacy -Wnon-virtual-dtor -felide-constructors -fno-exceptions -fno-rtti -mcpu=pentiumpro -O3 -fno-omit-frame-pointer!'\
	  -e 's!@''LDFLAGS''@!!'\
	  -e 's!@''CLIENT_LIBS''@!-lz -lcrypt -lnsl -lm  -L/usr/lib -lssl -lcrypto -lc -lnss_files -lnss_dns -lresolv -lc -lnss_files -lnss_dns -lresolv!' \
	  -e 's!@''LIBS''@!-lpthread -lz -lcrypt -lnsl -lm  -lpthread -lc -lnss_files -lnss_dns -lresolv -lc -lnss_files -lnss_dns -lresolv!' \
	  -e 's!@''WRAPLIBS''@!!' \
	  -e 's!@''innodb_system_libs''@!-lrt!' \
	  -e 's!@''openssl_libs''@!-L/usr/lib -lssl -lcrypto!' \
	  -e 's!@''VERSION''@!4.0.20a!' \
	  -e 's!@''MYSQL_SERVER_SUFFIX''@!!' \
	  -e 's!@''COMPILATION_COMMENT''@!Source distribution!' \
	  -e 's!@''MACHINE_TYPE''@!i686!' \
	  -e 's!@''HOSTNAME''@!/bin/hostname!' \
	  -e 's!@''SYSTEM_TYPE''@!pc-linux!' \
	  -e 's!@''CHECK_PID''@!/bin/kill -0 $$PID > /dev/null 2> /dev/null!' \
	  -e 's!@''FIND_PROC''@!/bin/ps p $$PID | grep mysqld > /dev/null!' \
	  -e 's!@''MYSQLD_DEFAULT_SWITCHES''@!--skip-locking!' \
	  -e 's!@''MYSQL_UNIX_ADDR''@!/tmp/mysql.sock!' \
	  -e 's!@''MYSQL_TCP_PORT''@!3306!' \
	  -e 's!@''IS_LINUX''@!true!' \
	  -e "s!@""CONF_COMMAND""@!./configure '--prefix=/usr/local/mysql' '--enable-assembler' '--with-extra-charsets=complex' '--with-innodb' '--with-berkeley-db' '--with-embedded-server' '--enable-thread-safe-client' '--with-openssl' '--with-vio' '--with-raid' '--enable-local-infile' 'CFLAGS=-Wimplicit -Wreturn-type -Wswitch -Wtrigraphs -Wcomment -W -Wchar-subscripts -Wformat -Wparentheses -Wsign-compare -Wwrite-strings -Wunused -mcpu=pentiumpro -O3 -fno-omit-frame-pointer' 'CXXFLAGS=-Wimplicit -Wreturn-type -Wswitch -Wtrigraphs -Wcomment -W -Wchar-subscripts -Wformat -Wparentheses -Wsign-compare -Wwrite-strings -Woverloaded-virtual -Wsign-promo -Wreorder -Wctor-dtor-privacy -Wnon-virtual-dtor -felide-constructors -fno-exceptions -fno-rtti -mcpu=pentiumpro -O3 -fno-omit-frame-pointer' 'CXX=ccache gcc'!" \
	  -e 's!@''MYSQLD_USER''@!mysql!' \
	$< > $@-t
	/bin/chmod +x $@-t
	/bin/mv $@-t $@

# Don't update the files from bitkeeper
%::SCCS/s.%
